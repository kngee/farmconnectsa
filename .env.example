# ── Backend (Express server, loaded from repo root) ──
TWILIO_ACCOUNT_SID=            # Twilio console → Account SID
TWILIO_AUTH_TOKEN=             # Twilio console → Auth Token (also used for webhook signature validation)
TWILIO_SANDBOX_NUMBER=         # Outbound WhatsApp sender, e.g. whatsapp:+14155238886
OPENAI_API_KEY=                # OpenAI API key for the AI vet responses
ADMIN_API_TOKEN=               # Shared secret for x-admin-token header (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
CRON_KEY=                      # Bearer token the external cron service sends to POST /api/cron/ingest-market (market/auction scrapers)
TWILIO_WEBHOOK_URL=            # Full public URL of the Twilio webhook, e.g. https://<your-ngrok-id>.ngrok-free.app/api/webhook/twilio (update when ngrok URL rotates)
SKIP_TWILIO_VALIDATION=false   # Set true ONLY for local curl testing — bypasses webhook signature checks
FIREBASE_SERVICE_KEY=          # Deployed environments only: full JSON contents of serviceAccountKey.json (locally the file itself is used instead)
FRONTEND_ORIGIN=               # Exact origin of the Netlify frontend for CORS, e.g. https://farmconnectsa.netlify.app (no trailing slash)
LEAD_ID_SALT=                  # Random secret salting marketplace lead IDs (generate like ADMIN_API_TOKEN); lead routes return 503 without it
# PORT=3000                    # Optional server port override

# ── Frontend (Vite, copy to src/frontend/.env) ──
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_API_BASE_URL=             # Express backend base URL, e.g. https://farmconnectsa.onrender.com (dev: http://localhost:3000)
